# OCI target. Root tenancy OCID works for Always Free resources, or use a compartment OCID.
OCI_COMPARTMENT_ID=ocid1.tenancy.oc1..example

# Comma-separated AD names exactly as OCI returns them, for example:
#   abcd:US-ASHBURN-AD-1,abcd:US-ASHBURN-AD-2,abcd:US-ASHBURN-AD-3
OCI_AVAILABILITY_DOMAINS=abcd:REGION-AD-1

# Ampere / Arm Always Free defaults. You may check up to 4 OCPUs and 24 GB RAM.
OCI_SHAPE=VM.Standard.A1.Flex
OCI_OCPUS=1
OCI_MEMORY_GB=6
# OCI_FAULT_DOMAIN=FAULT-DOMAIN-1

# Authentication: config for ~/.oci/config, or instance_principal when running on OCI.
OCI_AUTH=config
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT

# Optional webhook. Discord webhooks work with the content field; Slack-compatible webhooks use text.
# WEBHOOK_URL=https://discord.com/api/webhooks/...
NOTIFY_ON_UNAVAILABLE=false
OUTPUT_JSON=false
EXIT_NONZERO_WHEN_UNAVAILABLE=false
